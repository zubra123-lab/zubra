# Copia questo file in ".env" e inserisci i tuoi valori.

# Chiave Gemini (gratis) da https://aistudio.google.com/apikey
GEMINI_API_KEY=incolla-qui-la-tua-chiave

# Modello (i modelli "flash" rientrano nel piano gratuito)
GEMINI_MODEL=gemini-2.0-flash

# Scansioni gratuite al giorno per dispositivo
DAILY_FREE_LIMIT=10

# Porta del server
PORT=8787

# Origini ammesse per il Web. "*" va bene in sviluppo; in produzione
# metti il dominio della tua app, es. https://miaapp.web.app
ALLOWED_ORIGIN=*
